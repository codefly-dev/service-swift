apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ "{{" }} .Service.Name {{ "}}" }}
  namespace: {{ "{{" }} .Namespace {{ "}}" }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ "{{" }} .Service.Name {{ "}}" }}
  template:
    metadata:
      labels:
        app: {{ "{{" }} .Service.Name {{ "}}" }}
    spec:
      containers:
        - name: {{ "{{" }} .Service.Name {{ "}}" }}
          image: {{ "{{" }} .Image.FullName {{ "}}" }}
          ports:
            - containerPort: 8080
              name: http
          readinessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 30
