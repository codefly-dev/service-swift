{
  description = "{{ .Service.Name.DNSCase }} development environment";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
  };

  outputs = { self, nixpkgs }:
    let
      # Swift is nixpkgs-linux-only today; macOS users install Swift via
      # the Xcode toolchain. Only expose a Linux devShell to avoid a
      # confusing "pkgs.swift not available" error on Darwin.
      linuxSystems = [ "x86_64-linux" "aarch64-linux" ];
      forLinux = f: nixpkgs.lib.genAttrs linuxSystems (system: f system);
    in
    {
      devShells = forLinux (system:
        let
          pkgs = nixpkgs.legacyPackages.${system};
        in
        {
          default = pkgs.mkShell {
            packages = [
              pkgs.swift
              pkgs.swiftPackages.swiftpm
            ];
          };
        });
    };
}
